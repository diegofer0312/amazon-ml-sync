# ============================================
# RAINFOREST API (scraping confiable de Amazon)
# ============================================
# Obtén tu clave gratis en: https://www.rainforestapi.com
# Plan gratuito: 100 requests/mes. Sin tarjeta de crédito.
# Si está configurado, se usa como método principal de scraping.
RAINFOREST_API_KEY=

# ============================================
# CONFIGURACIÓN AMAZON (SP-API)
# ============================================
# Obtén estas credenciales en: https://sellercentral.amazon.com
# Developer > Aplicaciones > Añadir nueva aplicación
AMAZON_CLIENT_ID=amzn1.application-oa2-client.XXXXXXXXXXXXXXXX
AMAZON_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AMAZON_REFRESH_TOKEN=Atzr|XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AMAZON_MARKETPLACE_ID=A2Q3Y263D00KWC  # Colombia (o el país que uses)
AMAZON_REGION=us-east-1

# ============================================
# CONFIGURACIÓN MERCADO LIBRE
# ============================================
# Obtén estas credenciales en: https://developers.mercadolibre.com.co
# Mis apps > Crear aplicación
ML_APP_ID=XXXXXXXXXXXXXXX
ML_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ML_REDIRECT_URI=http://localhost:5173/auth/callback
ML_ACCESS_TOKEN=APP_USR-XXXXX  # Se actualiza automáticamente
ML_REFRESH_TOKEN=TG-XXXXX       # Se actualiza automáticamente
ML_SITE_ID=MCO                  # MCO = Colombia

# ============================================
# CONFIGURACIÓN DE PRECIOS
# ============================================
TRM_DEFAULT=4200          # Tasa de cambio USD a COP por defecto
ML_COMMISSION=0.11        # Comisión ML (11% por defecto)
DEFAULT_MARGIN=0.20       # Margen de ganancia (20% por defecto)
MIN_PRICE_COP=50000       # Precio mínimo en COP

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
PORT=3001
NODE_ENV=development
DATABASE_PATH=./data/sync.db
LOG_LEVEL=info

# ============================================
# SINCRONIZACIÓN AUTOMÁTICA
# ============================================
# Opciones: "*/1 * * * *" (cada min), "0 * * * *" (cada hora),
#           "0 */6 * * *" (cada 6h), "0 9 * * *" (diario a las 9am)
SYNC_CRON=0 * * * *
AUTO_UPDATE_TRM=true
